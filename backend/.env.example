# TripForge Backend Environment Variables
# Copy this file to .env and fill in your values

# ==========================================
# Application
# ==========================================
APP_ENV=development
DEBUG=false

# API Key for authentication (change in production!)
TRIPFORGE_API_KEY=dev-key-change-in-production

# ==========================================
# Supabase
# ==========================================
SUPABASE_URL=https://nrqqwgezhrbwtaeurpxj.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ==========================================
# Ollama (Local LLM)
# ==========================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_VISION_MODEL=llava:13b

# ==========================================
# Agent Configuration
# ==========================================
AGENT_MAX_TURNS=20
AGENT_TEMPERATURE=0.7
AGENT_TIMEOUT_SECONDS=120

# ==========================================
# Amadeus Flight Search API (Optional)
# Get credentials at: https://developers.amadeus.com/
# If not set, flight search will return mock data
# ==========================================
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
AMADEUS_ENVIRONMENT=test

# ==========================================
# Email (SendGrid - Optional)
# ==========================================
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@tripforge.app

# ==========================================
# Storage
# ==========================================
STORAGE_BUCKET=offers
PDF_GENERATION_TIMEOUT=30
